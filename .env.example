# ─────────────────────────────────────────────────────────
# Cricket Analytics Bot — Environment Configuration
# ─────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter API Key — leave empty to use local fallbacks
OPENROUTER_API_KEY=your_openrouter_api_key_here_or_empty

# Cricket data source
CRICKET_API_KEY=your_cricket_api_key_or_empty
CRICKET_API_PROVIDER=mock          # mock | cricapi | espn_scrape

# Database
DATABASE_URL=sqlite:///./data/cricket.db

# ML model path
MODEL_PATH=./data/models/xgb_v1.joblib

# ─────────────────────────────────────────────────────────
# Context-management / purge settings
# ─────────────────────────────────────────────────────────
# Maximum token window of the chosen LLM model
MODEL_MAX_TOKENS=200000

# Purge when ephemeral context exceeds this % of MODEL_MAX_TOKENS
CONTEXT_PURGE_PERCENT=50

# Hard token ceiling regardless of percentage (OR rule)
CONTEXT_HARD_LIMIT=100000

# Keep ephemeral messages even after purge (debug only)
FORCE_KEEP_EPHEMERAL=false

# LLM model for tiktoken estimation and OpenRouter calls
LLM_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/agents.log
